<mujoco model="Raccoon_S_chess_board_col">
  <include file="RaccoonBot_S.xml"/>
  <statistic center="0.0 0 0.2" extent="0.5"/>
  <!-- option 오버라이드 제거: RaccoonBot_S.xml의 검증된 물리 설정
       (timestep=0.0002, implicitfast, elliptic cone, noslip_iterations=100)을 그대로 사용.
       타임스텝 0.001은 그리퍼 접촉(solref=0.002)에 너무 커서 기물이 튕겨나갔음. -->

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <material name="groundplane" rgba="0.45 0.33 0.22 1" reflectance="0.0"/>
    <material name="white_piece" rgba="0.95 0.95 0.95 1"/>
    <material name="black_piece" rgba="0.20 0.20 0.23 1"/>
    <material name="cell_light" rgba="0.95 0.95 0.95 1"/>
    <material name="cell_dark"  rgba="0.30 0.30 0.34 1"/>
    <mesh name="bishop_mesh" file="chess_bishop.stl" scale="0.001 0.001 0.001"/>
    <!-- 주의: STL 파일명이 룩<->나이트로 바뀌어 저장돼 있음.
         실제 룩 형상은 chess_knight.stl에 들어있으므로 rook_mesh는 그 파일을 가리킨다. -->
    <mesh name="rook_mesh" file="chess_knight.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0.5 0.5 0.05" type="plane" material="groundplane"/>

    <!-- 실린더 베이스라인 카메라로 복구 
    <camera name="front_view" pos="0.0 0.50 0.13" xyaxes="-1 0 0 0 -0.18 0.98" fovy="45"/>-->
    <camera name="front_view" pos="0.0 0.43 0.28" xyaxes="-1 0 0 0 -0.530 0.848" fovy="50"/>

    <geom name="cell_a1" type="box" pos="-0.06 0.08 0.001" size="0.03 0.03 0.001" material="cell_dark"/>
    <geom name="cell_b1" type="box" pos=" 0.00 0.08 0.001" size="0.03 0.03 0.001" material="cell_light"/>
    <geom name="cell_c1" type="box" pos=" 0.06 0.08 0.001" size="0.03 0.03 0.001" material="cell_dark"/>

    <geom name="cell_a2" type="box" pos="-0.06 0.14 0.001" size="0.03 0.03 0.001" material="cell_light"/>
    <geom name="cell_b2" type="box" pos=" 0.00 0.14 0.001" size="0.03 0.03 0.001" material="cell_dark"/>
    <geom name="cell_c2" type="box" pos=" 0.06 0.14 0.001" size="0.03 0.03 0.001" material="cell_light"/>

    <geom name="cell_a3" type="box" pos="-0.06 0.20 0.001" size="0.03 0.03 0.001" material="cell_dark"/>
    <geom name="cell_b3" type="box" pos=" 0.00 0.20 0.001" size="0.03 0.03 0.001" material="cell_light"/>
    <geom name="cell_c3" type="box" pos=" 0.06 0.20 0.001" size="0.03 0.03 0.001" material="cell_dark"/>

    <body name="bishop" pos="-0.06 0.14 0.02">
      <freejoint/>
      <inertial pos="0 0 0.025" mass="0.028" diaginertia="6.0e-5 6.0e-5 1.5e-5"/>

      <geom type="mesh" mesh="bishop_mesh" pos="-0.0161 -0.0161 0" material="black_piece" contype="0" conaffinity="0" group="2"/>

      <!-- 아래쪽 바닥 접촉부: 흔들림 감쇠용 중간값 -->
      <geom type="cylinder" size="0.0162 0.0036" pos="0 0 0.0036" group="3" friction="1.2 0.03 0.005" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0160 0.0036" pos="0 0 0.0107" group="3" friction="1.2 0.03 0.005" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0135 0.0036" pos="0 0 0.0179" group="3" friction="1.2 0.03 0.005" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>

      <!-- 중간/위쪽 그리퍼 접촉부: 기존 유지 -->
      <geom type="cylinder" size="0.0085 0.0036" pos="0 0 0.0250" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0057 0.0036" pos="0 0 0.0322" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0059 0.0036" pos="0 0 0.0393" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0116 0.0036" pos="0 0 0.0465" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0110 0.0036" pos="0 0 0.0536" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0105 0.0036" pos="0 0 0.0608" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0097 0.0036" pos="0 0 0.0679" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0036 0.0036" pos="0 0 0.0751" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0047 0.0036" pos="0 0 0.0822" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
    </body>

    <body name="rook" pos="0.06 0.14 0.02">
      <freejoint/>
      <inertial pos="0 0 0.025" mass="0.014" diaginertia="6.0e-5 6.0e-5 1.5e-5"/>

      <geom type="mesh" mesh="rook_mesh" pos="-0.0184 -0.0183 0" material="white_piece" contype="0" conaffinity="0" group="2"/>

      <!-- 아래쪽 바닥 접촉부: 흔들림 감쇠용 중간값 -->
      <geom type="cylinder" size="0.0185 0.0025" pos="0 0 0.0025" group="3" friction="1.2 0.03 0.005" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0178 0.0025" pos="0 0 0.0076" group="3" friction="1.2 0.03 0.005" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0177 0.0025" pos="0 0 0.0126" group="3" friction="1.2 0.03 0.005" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>

      <!-- 중간/위쪽 그리퍼 접촉부: 기존 유지 -->
      <geom type="cylinder" size="0.0149 0.0025" pos="0 0 0.0177" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0125 0.0025" pos="0 0 0.0227" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0099 0.0025" pos="0 0 0.0278" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0095 0.0025" pos="0 0 0.0328" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0096 0.0025" pos="0 0 0.0379" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0106 0.0025" pos="0 0 0.0429" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0143 0.0025" pos="0 0 0.0480" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0146 0.0025" pos="0 0 0.0530" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
      <geom type="cylinder" size="0.0146 0.0025" pos="0 0 0.0580" group="3" friction="2 0.5 0.1" condim="6" solimp="0.97 0.99 0.001" solref="0.005 1"/>
    </body>

  </worldbody>
</mujoco>